# Python bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
OPENAI_API_KEY=your_openai_api_key_here
ADMIN_GROUP_ID=-1000000000000
PUBLIC_BASE_URL=https://your-public-url-or-ngrok-tunnel.example

# Supabase (shared)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Dashboard (Next.js on Vercel) – set all of these in Vercel Environment Variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Must be your live domain (e.g. https://temptagbot.com) so Stripe redirects to it, not a Vercel preview URL
NEXT_PUBLIC_BASE_URL=https://temptagbot.com
OPENAI_API_KEY=your_openai_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_xxxx
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Render (Python bot) – set in Render service Environment
# TELEGRAM_BOT_TOKEN, STRIPE_SECRET_KEY, OPENAI_API_KEY, ADMIN_GROUP_ID,
# PUBLIC_BASE_URL (e.g. https://your-app.vercel.app), SUPABASE_URL, SUPABASE_SERVICE_KEY
